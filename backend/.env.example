# --- Backend do verbus (DevLingo) — copie para .env no servidor e preencha ---

# Porta do serviço (no servidor LocalDeploy, próxima livre = 8006).
PORT=8006

# Segredo do JWT — gere um valor longo e aleatório, ex.: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-aleatorio-longo

# Caminho do banco SQLite no servidor (armazena os dados de forma persistente).
# Recomendado fora da pasta do git, ex.: /home/v/storage/verbus.db
VERBUS_DB=/home/v/storage/verbus.db

# Nível de log (info | warn | error | debug)
LOG_LEVEL=info
